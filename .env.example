# ============================================================
#  IBM Naukri Agent — Environment Configuration Template
#  Copy this file to .env and fill in your credentials.
#  NEVER commit .env to version control.
# ============================================================

# --- Flask Core ---
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-super-secret-flask-key-change-in-production
DEBUG=True

# --- IBM watsonx.ai ---
WATSONX_API_KEY=your-ibm-cloud-api-key
WATSONX_PROJECT_ID=your-watsonx-project-id
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-13b-chat-v2

# --- IBM Orchestrate ---
IBM_ORCHESTRATE_API_KEY=your-orchestrate-api-key
IBM_ORCHESTRATE_URL=https://api.us-south.orchestrate.cloud.ibm.com/v1
IBM_ORCHESTRATE_INSTANCE_ID=your-orchestrate-instance-id

# --- IBM Watson Discovery (RAG) ---
WATSON_DISCOVERY_API_KEY=your-discovery-api-key
WATSON_DISCOVERY_URL=https://api.us-south.discovery.watson.cloud.ibm.com
WATSON_DISCOVERY_ENV_ID=your-discovery-environment-id
WATSON_DISCOVERY_COLLECTION_ID=your-discovery-collection-id

# --- IBM Cloud Object Storage (resume/doc storage) ---
IBM_COS_API_KEY=your-cos-api-key
IBM_COS_INSTANCE_ID=your-cos-instance-id
IBM_COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
IBM_COS_BUCKET=naukri-agent-uploads

# --- Database ---
DATABASE_URL=sqlite:///naukri_agent.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/naukri_agent

# --- Redis (optional — session / task queue) ---
REDIS_URL=redis://localhost:6379/0

# --- App Settings ---
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=pdf,docx,doc,txt

# --- Email (notifications) ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# --- Admin ---
ADMIN_EMAIL=admin@naukriagent.com
ADMIN_PASSWORD=Admin@123456
